{
  "name": "balochsath-next",
  "version": "3.0.0",
  "description": "Bait ul Maal BalochSath — Phase 3 modern rebuild (Next.js 16 + Postgres + Supabase)",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "import:legacy": "tsx scripts/migrate-localstorage.ts",
    "build:cf": "npx @cloudflare/next-on-pages",
    "deploy:cf": "npm run build:cf && wrangler pages deploy .vercel/output/static --project-name=balochsath",
    "preview:cf": "npm run build:cf && wrangler pages dev .vercel/output/static --compatibility-flag=nodejs_compat"
  },
  "dependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.5",
    "zod": "^3.23.8",
    "zustand": "^5.0.1",
    "@tanstack/react-query": "^5.59.20",
    "lucide-react": "^0.460.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4",
    "class-variance-authority": "^0.7.1",
    "next-themes": "^0.4.3",
    "sonner": "^1.7.0",
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.2",
    "eslint": "^9.14.0",
    "eslint-config-next": "^16.0.0",
    "@cloudflare/next-on-pages": "^1.13.5",
    "wrangler": "^3.86.0",
    "vercel": "^39.0.0"
  }
}
