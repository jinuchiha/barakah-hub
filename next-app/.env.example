# Copy to .env.local and fill in your Supabase project credentials.
# Your project: https://supabase.com/dashboard/project/oryyeqdyhmagvjvbgvkt
# Get keys at:  https://supabase.com/dashboard/project/oryyeqdyhmagvjvbgvkt/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://oryyeqdyhmagvjvbgvkt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only (NEVER commit, NEVER expose client-side).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Postgres connection — Settings → Database → Connection String → Transaction mode (port 6543).
# https://supabase.com/dashboard/project/oryyeqdyhmagvjvbgvkt/settings/database
DATABASE_URL=postgresql://postgres.oryyeqdyhmagvjvbgvkt:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Optional — Sentry, PostHog
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
