# Copy to .env.local and fill in your Supabase project credentials
# Get these from: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# For server-side admin operations (server actions, route handlers)
# NEVER expose this client-side
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Postgres connection — get from Supabase → Project Settings → Database → Connection String (Transaction mode for app, Session mode for migrations)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Optional — Sentry, PostHog
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
