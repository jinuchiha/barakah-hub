# ═══════════════════════════════════════════════════════════════════
# Barakah Hub — environment template
# Copy to `.env.local` and fill in real values from your Supabase project.
# Never commit the populated file (it is gitignored via `.env.*`).
# ═══════════════════════════════════════════════════════════════════

# Supabase project URL + anon (public) key.
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service-role key — server-only. NEVER expose client-side.
# Used by the localStorage migration script and any future admin tooling.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Postgres connection string — Settings → Database → Connection String →
# Transaction mode (port 6543) is required for prepared-statement-free
# pooling that the Drizzle client expects.
DATABASE_URL=postgresql://postgres.<your-project>:YOUR_PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── Optional observability hooks (P3 backlog) ──────────────────────
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
