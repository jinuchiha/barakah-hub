# ═══════════════════════════════════════════════════════════════════
# Barakah Hub — environment template (Neon + Better-Auth)
# Copy to `.env.local` and fill in real values.
# Never commit the populated file (it is gitignored via `.env.*`).
# ═══════════════════════════════════════════════════════════════════

# ── Neon Postgres ──────────────────────────────────────────────────
# Pooled connection (PgBouncer-fronted) — used by app runtime.
# Get via: `neonctl connection-string production --pooled`
DATABASE_URL=postgresql://<user>:<pw>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require

# Direct connection (no pooler) — required by drizzle-kit / our migrate
# script because PgBouncer transaction mode rejects DDL prepared statements.
# Get via: `neonctl connection-string production`
DATABASE_URL_DIRECT=postgresql://<user>:<pw>@<host>.<region>.aws.neon.tech/<db>?sslmode=require

# ── Better-Auth ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Must be ≥32 chars. App will throw at boot if unset, default, or shorter.
BETTER_AUTH_SECRET=

# Origin used for CSRF / cookie domain. Set to the deployed URL in prod.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email transport (Resend) — for password-reset delivery (optional) ─
# RESEND_API_KEY=re_...
# RESEND_FROM=Barakah Hub <noreply@yourdomain.com>

# ── Object storage (Cloudflare R2) — Phase 6, not yet wired ────────
# R2_ACCOUNT_ID=<cloudflare-account-id>
# R2_ACCESS_KEY_ID=<r2-token-id>
# R2_SECRET_ACCESS_KEY=<r2-token-secret>
# R2_PUBLIC_URL=https://pub-<id>.r2.dev

# ── Optional observability hooks (P3 backlog) ──────────────────────
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
