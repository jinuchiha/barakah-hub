# ═══════════════════════════════════════════════════════════════════
# Barakah Hub — environment template (Neon + Supabase Auth + R2)
# Copy to `.env.local` and fill in real values.
# Never commit the populated file (it is gitignored via `.env.*`).
# ═══════════════════════════════════════════════════════════════════

# ── Neon Postgres ──────────────────────────────────────────────────
# Pooled connection (PgBouncer-fronted) — use for app traffic.
# Get via: `neonctl connection-string production --pooled`
DATABASE_URL=postgresql://<user>:<pw>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require

# Direct connection (no pooler) — required for Drizzle Kit migrations
# because PgBouncer transaction mode rejects DDL prepared statements.
# Get via: `neonctl connection-string production`
DATABASE_URL_DIRECT=postgresql://<user>:<pw>@<host>.<region>.aws.neon.tech/<db>?sslmode=require

# ── Supabase (Auth only — DB has been migrated to Neon) ────────────
# These can be removed once Phase 5 (Auth migration) is complete and
# Better-Auth/Clerk/etc. has replaced supabase.auth.* throughout the app.
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service-role key — server-only. NEVER expose client-side.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Object storage (Cloudflare R2) — set after Phase 6 ──────────────
# R2_ACCOUNT_ID=<cloudflare-account-id>
# R2_ACCESS_KEY_ID=<r2-token-id>
# R2_SECRET_ACCESS_KEY=<r2-token-secret>
# R2_PUBLIC_URL=https://pub-<id>.r2.dev

# ── Optional observability hooks (P3 backlog) ──────────────────────
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
