{
  "expo": {
    "name": "Barakah Hub",
    "slug": "barakah-hub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "barakah",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "backgroundColor": "#0a0a0f",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.barakah.hub",
      "infoPlist": {
        "NSCameraUsageDescription": "Upload payment screenshots and scan receipts",
        "NSPhotoLibraryUsageDescription": "Select payment proof from gallery",
        "NSFaceIDUsageDescription": "Use Face ID to unlock Barakah Hub",
        "NSPhotoLibraryAddUsageDescription": "Save receipts to your photo library"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.barakah.hub",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "softwareKeyboardLayoutMode": "pan",
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "barakah.app",
              "pathPrefix": "/case"
            },
            {
              "scheme": "https",
              "host": "barakah.app",
              "pathPrefix": "/payment"
            },
            {
              "scheme": "https",
              "host": "barakah.app",
              "pathPrefix": "/notifications"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "data": [
            { "scheme": "barakah" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#00e676",
          "sounds": [],
          "mode": "production"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Barakah Hub to use camera to capture payment receipts."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Barakah Hub to access your photos for payment proof.",
          "cameraPermission": "Allow Barakah Hub to use camera to capture payment proof."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Barakah Hub to use Face ID for fast, secure authentication."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
